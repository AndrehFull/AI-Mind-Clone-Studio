# ─────────────────────────────────────────────────────────────
# Mind Clone Studio — environment variables
# Copy this file to ".env.local" and fill in your own keys.
# ─────────────────────────────────────────────────────────────

# OpenAI — used for embeddings (RAG) AND the chat/analysis model.
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embedding model. MUST stay text-embedding-3-large (3072 dims) to match
# the documents table / vector column defined in db/schema.sql.
OPENAI_EMBED_MODEL=text-embedding-3-large

# Chat model used to generate conversations and structured analysis.
# Any OpenAI chat model works (e.g. gpt-5, gpt-4o, gpt-4o-mini).
OPENAI_CHAT_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# Database — Postgres + pgvector. Server-side ONLY.
#
# Keep the localhost default below. It is used when you run the app on your
# machine (npm run dev). When you run the FULL stack with `docker compose up`,
# the compose file automatically overrides this to reach the bundled db
# service — you don't need to change anything.
#
# Using your own Postgres instead? Point this at it. For Supabase, use the
# "Direct connection" string (Settings → Database → Connection string → URI).
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mindclone

# ─────────────────────────────────────────────────────────────
# API wiring. The Next frontend talks to the FastAPI backend over HTTP.
#   NEXT_PUBLIC_API_BASE_URL — where the BROWSER reaches the API.
#   API_INTERNAL_URL        — where SSR reaches the API (compose network).
# The docker compose file sets these for you; the defaults below cover plain
# local dev (uvicorn on :8000 + next dev on :3000).
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_URL=http://localhost:8000
